let state = {
  currentCode: null,
  watchlist: JSON.parse(localStorage.getItem('watchlist') || '[]'),
  filter: 'all',
  chartPeriod: '1d',
  side: 'buy',
  apiKey: localStorage.getItem('apiKey') || '',
  order: {}
};

// ============================================================
// Screen management
// ============================================================
function showScreen(name) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('scr-' + name).classList.add('active');
  window.scrollTo(0, 0);
}

function switchNav(name, el) {
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  showScreen(name);
  if (name === 'heat') renderHeatmap();
  if (name === 'watch') renderWatchlist();
}

// ============================================================
// Home / stock list
// ============================================================
document.getElementById('home-filter').addEventListener('click', e => {
  const chip = e.target.closest('.chip');
  if (!chip) return;
  document.querySelectorAll('#home-filter .chip').forEach(c => c.classList.remove('active'));
  chip.classList.add('active');
  state.filter = chip.dataset.f;
  renderHome();
});

const CATS = [
  {key:'day-stable',  period:'デイトレ',   style:'安定重視',    f:s=>s.best==='day'&&s.style==='stable'},
  {key:'day-growth',  period:'デイトレ',   style:'リターン重視', f:s=>s.best==='day'&&s.style==='growth'},
  {key:'short-stable',period:'短期',        style:'安定重視',    f:s=>s.best==='short'&&s.style==='stable'},
  {key:'short-growth',period:'短期',        style:'リターン重視', f:s=>s.best==='short'&&s.style==='growth'},
  {key:'long-stable', period:'長期',        style:'安定重視',    f:s=>s.best==='long'&&s.style==='stable'},
  {key:'long-growth', period:'長期',        style:'リターン重視', f:s=>s.best==='long'&&s.style==='growth'},
];
const PERIOD_COLOR = {デイトレ:'#f59e0b',短期:'#3b82f6',長期:'#8b5cf6'};

function renderHome() {
  const f = state.filter;
  const allCodes = Object.keys(DB);
  const filtered = allCodes.filter(code => {
    const s = DB[code];
    if (f === 'all') return true;
    if (f === 'day') return s.best === 'day';
    if (f === 'short') return s.best === 'short';
    if (f === 'long') return s.best === 'long';
    if (f === 'stable') return s.style === 'stable';
    if (f === 'growth') return s.style === 'growth';
    return true;
  });

  const visibleCats = CATS.filter(c => {
    if (f === 'all') return true;
    const [period] = c.key.split('-');
    if (f === 'day' || f === 'short' || f === 'long') return period === f;
    return true;
  });

  let html = '';
  visibleCats.forEach(cat => {
    const stocks = filtered.filter(code => cat.f(DB[code]));
    const pc = PERIOD_COLOR[cat.period] || '#888';
    html += `<div style="margin-bottom:4px">
      <div style="display:flex;align-items:center;gap:8px;padding:8px 16px 4px">
        <span style="width:3px;height:16px;background:${pc};border-radius:2px;display:inline-block"></span>
        <span style="font-size:13px;font-weight:700">${cat.period}</span>
        <span style="font-size:11px;padding:2px 8px;border-radius:20px;background:${cat.style==='安定重視'?'var(--green-bg)':'var(--red-bg)'};color:${cat.style==='安定重視'?'var(--green-text)':'var(--red-text)'}">${cat.style}</span>
      </div>
      <div style="background:var(--bg);border-top:0.5px solid var(--border);border-bottom:0.5px solid var(--border)">`;
    if (stocks.length === 0) {
      html += `<div style="padding:12px 16px;font-size:12px;color:var(--text3);font-style:italic">該当銘柄なし</div>`;
    } else {
      stocks.forEach(code => {
        const s = DB[code];
        const up = s.chg >= 0;
        const starred = state.watchlist.includes(code);
        html += `<div class="stock-row" onclick="selectStock('${code}')">
          <span class="s-code">${code}</span>
          <div style="flex:1;min-width:0">
            <div class="s-name">${s.name}</div>
            <div style="font-size:11px;color:var(--text2)">${s.sector} · リスク:${s.best==='day'?'高':s.best==='short'?'中':'低〜中'}</div>
          </div>
          <div class="s-right">
            <div class="s-price">¥${s.price.toLocaleString()}</div>
            <div class="s-chg" style="color:${up?'var(--green)':'var(--red)'}">${up?'+':''}${s.chgPct.toFixed(2)}%</div>
          </div>
          <span style="font-size:20px;padding-left:8px" onclick="event.stopPropagation();quickStar('${code}')">${starred?'★':'☆'}</span>
        </div>`;
      });
    }
    html += `</div></div>`;
  });
  document.getElementById('home-list').innerHTML = html;
}

function quickStar(code) {
  const idx = state.watchlist.indexOf(code);
  if (idx >= 0) state.watchlist.splice(idx, 1);
  else state.watchlist.push(code);
  localStorage.setItem('watchlist', JSON.stringify(state.watchlist));
  renderHome();
}

