function goToOrder() {
  const s = DB[state.currentCode];
  const bestRec = s.best==='day'?s.rec_day:s.best==='short'?s.rec_short:s.rec_long;
  document.getElementById('order-stock-info').textContent = `${s.name}（${state.currentCode}）· 推奨指値 ¥${bestRec.toLocaleString()}`;
  document.getElementById('inp-price').value = bestRec;
  document.getElementById('inp-qty').value = '';
  state.side = 'buy';
  updateSideBtn();
  calcOrder();
  showScreen('order');
}

function setSide(s) {
  state.side = s;
  updateSideBtn();
}

function updateSideBtn() {
  document.getElementById('side-buy').className = 'seg-btn' + (state.side==='buy'?' active-buy':'');
  document.getElementById('side-sell').className = 'seg-btn' + (state.side==='sell'?' active-sell':'');
}

function setTP(pct) {
  const p = parseFloat(document.getElementById('inp-price').value) || 0;
  if (!p) return;
  document.querySelectorAll('#tp-chips .chip').forEach(c=>c.classList.remove('active'));
  event.target.classList.add('active');
}

function calcOrder() {
  const p = parseFloat(document.getElementById('inp-price').value) || 0;
  const q = parseFloat(document.getElementById('inp-qty').value) || 0;
  const total = p * q;
  const sl5 = Math.round(p * .95) * q;
  document.getElementById('tot-amount').textContent = total > 0 ? total.toLocaleString() + ' 円' : '— 円';
  document.getElementById('tot-sl').textContent = sl5 > 0 ? Math.round(p*.95).toLocaleString() + ' 円/株' : '— 円';
  document.getElementById('order-warn').style.display = total > 75000 && total > 0 ? 'block' : 'none';
  state.order = { code: state.currentCode, name: DB[state.currentCode]?.name, side: state.side, price: p, qty: q, total };
}

function goToConfirm() {
  const { code, name, side, price, qty, total } = state.order;
  if (!price || !qty) { alert('指値と株数を入力してください'); return; }
  const sl5 = Math.round(price * .95);
  document.getElementById('confirm-summary').innerHTML = `
    <div class="sl-row"><span style="color:var(--text2)">銘柄</span><span style="font-weight:700">${code} ${name}</span></div>
    <div class="sl-row"><span style="color:var(--text2)">売買</span><span style="font-weight:700;color:${side==='buy'?'var(--green)':'var(--red)'}">${side==='buy'?'買い':'売り'}</span></div>
    <div class="sl-row"><span style="color:var(--text2)">注文種別</span><span>指値</span></div>
    <div class="sl-row"><span style="color:var(--text2)">指値</span><span style="font-weight:700">¥${price.toLocaleString()}</span></div>
    <div class="sl-row"><span style="color:var(--text2)">株数</span><span style="font-weight:700">${qty.toLocaleString()} 株</span></div>
    <div class="sl-row"><span style="color:var(--text2)">概算合計</span><span style="font-weight:700;font-size:17px">¥${total.toLocaleString()}</span></div>
    <div class="sl-row"><span style="color:var(--text2)">損切ライン（-5%）</span><span style="color:var(--red);font-weight:700">¥${sl5.toLocaleString()}</span></div>`;
  showScreen('confirm');
}

function showGuide() {
  const { code, name, price, qty, total, side } = state.order;
  document.getElementById('g-code').textContent = `コード：${code}（${name}）`;
  document.getElementById('g-detail').textContent = `${side==='buy'?'現物買い':'現物売り'} · 指値 ¥${price?.toLocaleString()} × ${qty}株（計 ¥${total?.toLocaleString()}）`;
  document.getElementById('guide-summary').innerHTML = `<div style="display:flex;justify-content:space-between"><span>${code} ${name}</span><span style="font-weight:700">¥${total?.toLocaleString()}</span></div>`;
  showScreen('guide');
}

// ============================================================
// Heatmap
// ============================================================
function renderHeatmap() {
  document.getElementById('heat-grid').innerHTML = SECTORS.map(sec => {
    const up = sec.chg >= 0;
    const intensity = Math.min(Math.abs(sec.chg) / 2, 1);
    const bg = up ? `rgba(22,163,74,${.15+intensity*.5})` : `rgba(220,38,38,${.15+intensity*.5})`;
    const tc = up ? '#14532d' : '#7f1d1d';
    return `<div class="heat-cell" style="background:${bg}" onclick="showHeatDetail('${sec.name}')">
      <div class="heat-name" style="color:${tc}">${sec.name}</div>
      <div class="heat-chg" style="color:${tc}">${up?'+':''}${sec.chg.toFixed(1)}%</div>
    </div>`;
  }).join('');
}

function showHeatDetail(name) {
  const sec = SECTORS.find(s => s.name === name);
  if (!sec) return;
  const detail = document.getElementById('heat-detail');
  detail.style.display = 'block';
  document.getElementById('heat-detail-title').textContent = name + ' セクター';
  if (sec.codes.length === 0) {
    document.getElementById('heat-detail-list').innerHTML = `<div style="font-size:12px;color:var(--text3);padding:10px 0">銘柄データなし</div>`;
    return;
  }
  document.getElementById('heat-detail-list').innerHTML = sec.codes.map(code => {
    const s = DB[code]; if (!s) return '';
    const up = s.chg >= 0;
    return `<div class="stock-row" onclick="selectStock('${code}')">
      <span class="s-code">${code}</span>
      <span class="s-name">${s.name}</span>
      <div class="s-right">
        <div class="s-price">¥${s.price.toLocaleString()}</div>
        <div class="s-chg" style="color:${up?'var(--green)':'var(--red)'}">${up?'+':''}${s.chgPct.toFixed(2)}%</div>
      </div>
    </div>`;
  }).join('');
}

// ============================================================
// Watchlist
// ============================================================
function renderWatchlist() {
  const el = document.getElementById('watch-list');
  if (state.watchlist.length === 0) {
    el.innerHTML = `<div style="text-align:center;padding:48px 20px;color:var(--text3)"><div style="font-size:36px;margin-bottom:10px">⭐</div><div>気になる銘柄の ☆ を押して登録</div></div>`;
    return;
  }
  el.innerHTML = state.watchlist.map(code => {
    const s = DB[code]; if (!s) return '';
    const up = s.chg >= 0;
    const bestRec = s.best==='day'?s.rec_day:s.best==='short'?s.rec_short:s.rec_long;
    const bestTgt = s.best==='day'?s.tgt_day:s.best==='short'?s.tgt_short:s.tgt_long;
    const sl5 = Math.round(bestRec * .95);
    return `<div class="watch-row" onclick="selectStock('${code}')">
      <div class="watch-top">
        <span class="s-code">${code}</span>
        <span class="s-name">${s.name}</span>
        <div class="s-right">
          <div class="s-price">¥${s.price.toLocaleString()}</div>
          <div class="s-chg" style="color:${up?'var(--green)':'var(--red)'}">${up?'+':''}${s.chgPct.toFixed(2)}%</div>
        </div>
        <span style="font-size:20px;padding-left:8px" onclick="event.stopPropagation();quickStar('${code}');renderWatchlist()">★</span>
      </div>
      <div class="watch-tags">
        <span class="badge badge-blue">指値 ¥${bestRec.toLocaleString()}</span>
        <span class="badge badge-up">目標 ¥${bestTgt.toLocaleString()}</span>
        <span class="badge badge-dn">損切 ¥${sl5.toLocaleString()}</span>
      </div>
    </div>`;
  }).join('');
}

// ============================================================
// Init
// ============================================================
renderHome();
renderHeatmap();

// SW register
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('sw.js').catch(() => {});
}
</script>
</body>
</html>
