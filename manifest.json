  const profit = Math.round((bestTgt-bestRec)/bestRec*1000)/10;
  document.getElementById('strat-content').innerHTML = `
    <div class="strat strat-day${s.best==='day'?' best':''}">
      <div class="strat-title">デイトレ${s.best==='day'?' ← AIおすすめ':''}</div>
