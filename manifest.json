// AI Analysis via Claude API
async function fetchAI(code, s) {
  const aiEl = document.getElementById('ai-content');
  const statusEl = document.getElementById('ai-status');
  aiEl.innerHTML = `<div class="ai-loading"><div class="spinner"></div><span>AIが分析中...</span></div>`;
  statusEl.textContent = '';
  try {
    const prompt = `あなたは日本株の分析アシスタントです。以下の銘柄を初心者向けに分析してください。

銘柄: ${s.name}（${code}）
現在値: ¥${s.price.toLocaleString()}（前日比 ${s.chg>=0?'+':''}${s.chgPct.toFixed(2)}%）
セクター: ${s.sector}
PBR: ${s.pbr}倍 / PER: ${s.per??'赤字'}倍 / ROE: ${s.roe}% / 配当: ${s.div}%
RSI: ${s.rsi} / MACD: ${s.macd}
サポート: ¥${s.support.toLocaleString()} / レジスタンス: ¥${s.resist.toLocaleString()}

以下の3点を簡潔に（合計150字以内）日本語で答えてください：
1. 今の状況（1〜2文）
2. 注目ポイント（1文）
3. 初心者へのアドバイス（1文）`;

    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        messages: [{ role: 'user', content: prompt }]
      })
    });
    const data = await res.json();
    const text = data.content?.[0]?.text || 'AI分析を取得できませんでした。';
    aiEl.innerHTML = `<div class="ai-box">${text.replace(/\n/g,'<br>')}</div>`;
    statusEl.textContent = '(Claude AI)';
  } catch(e) {
    aiEl.innerHTML = `<div class="ai-box">${s.name}は${s.sector}セクターの銘柄です。${s.rsi>60?'テクニカルは強め':'RSIが落ち着いており底値圏'}で、${s.best==='long'?'長期保有':s.best==='short'?'短期売買':'デイトレ'}に向いた局面です。初心者は${s.best==='day'?'まず少額で様子を見ましょう':'損切りラインを決めてから入りましょう'}。</div>`;
    statusEl.textContent = '(ローカル)';
  }
}

