function selectStock(code) {
  state.currentCode = code;
  state.chartPeriod = '1d';
  const s = DB[code];
  document.getElementById('a-name').textContent = s.name;
  document.getElementById('a-meta').textContent = `${code} · ${s.sector} · ${s.mcap}`;
  document.getElementById('a-price').textContent = `¥${s.price.toLocaleString()}`;
  const up = s.chg >= 0;
  document.getElementById('a-chg').innerHTML = `<span class="badge ${up?'badge-up':'badge-dn'}">${up?'+':''}${s.chg}円 (${up?'+':''}${s.chgPct.toFixed(2)}%)</span>`;
  document.getElementById('a-high').textContent = `¥${s.high.toLocaleString()}`;
  document.getElementById('a-low').textContent = `¥${s.low.toLocaleString()}`;
  document.getElementById('watch-star').textContent = state.watchlist.includes(code) ? '★' : '☆';

  renderChart();
  renderFund();
  renderTech();
  renderSig();
  renderNews();
  renderSL();
  renderStrat();

  // Reset tab
  document.querySelectorAll('#scr-analysis .tab').forEach(t => t.classList.remove('active'));
  document.querySelector('#scr-analysis .tab').classList.add('active');
  ['fund','tech','sig','news'].forEach(t => {
    document.getElementById('tab-'+t).style.display = t==='fund' ? 'block' : 'none';
  });

  // AI
  fetchAI(code, s);

  showScreen('analysis');
}

// Chart
document.getElementById('chart-periods').addEventListener('click', e => {
  const chip = e.target.closest('.chip');
  if (!chip) return;
  document.querySelectorAll('#chart-periods .chip').forEach(c => c.classList.remove('active'));
  chip.classList.add('active');
  state.chartPeriod = chip.dataset.p;
  renderChart();
});

function renderChart() {
  const code = state.currentCode;
  if (!code) return;
  const s = DB[code];
  const key = 'c' + state.chartPeriod.replace('-','');
  const data = s[key] || s.c1d;
  const area = document.getElementById('main-chart');
  area.innerHTML = '';
  const mn = Math.min(...data), mx = Math.max(...data), rng = mx - mn || 1;
  const H = 100, W = 360, pad = 4;
  const up = data[data.length-1] >= data[0];
  const lc = up ? '#16a34a' : '#dc2626';
  const fc = up ? 'rgba(22,163,74,.15)' : 'rgba(220,38,38,.12)';
  const xs = data.map((_,i) => pad + i*(W-pad*2)/(data.length-1));
  const ys = data.map(v => H - Math.round((v-mn)/rng*H*.86+H*.07));
  const svg = document.createElementNS('http://www.w3.org/2000/svg','svg');
  svg.setAttribute('viewBox', `0 0 ${W} ${H+14}`);
  svg.setAttribute('width','100%');
  svg.style.cssText = 'display:block;overflow:visible';
  const ap = document.createElementNS('http://www.w3.org/2000/svg','path');
  ap.setAttribute('d',`M${xs[0]} ${H} L${xs.map((x,i)=>x+' '+ys[i]).join('L')} L${xs[xs.length-1]} ${H}Z`);
  ap.setAttribute('fill',fc); svg.appendChild(ap);
  const lp = document.createElementNS('http://www.w3.org/2000/svg','path');
  lp.setAttribute('d',`M${xs.map((x,i)=>x+' '+ys[i]).join('L')}`);
  lp.setAttribute('fill','none'); lp.setAttribute('stroke',lc); lp.setAttribute('stroke-width','2');
  lp.setAttribute('stroke-linecap','round'); lp.setAttribute('stroke-linejoin','round'); svg.appendChild(lp);
  if(data.length>=5){
    const m5=data.map((_,i)=>{if(i<4)return null;const a=data.slice(i-4,i+1).reduce((s,v)=>s+v,0)/5;return{x:xs[i],y:H-Math.round((a-mn)/rng*H*.86+H*.07)};}).filter(Boolean);
    if(m5.length>1){const p=document.createElementNS('http://www.w3.org/2000/svg','path');p.setAttribute('d',`M${m5.map(p=>p.x+' '+p.y).join('L')}`);p.setAttribute('fill','none');p.setAttribute('stroke','#f59e0b');p.setAttribute('stroke-width','1.5');p.setAttribute('stroke-dasharray','5 3');svg.appendChild(p);}
  }
  if(data.length>=12){
    const m25=data.map((_,i)=>{if(i<11)return null;const a=data.slice(Math.max(0,i-11),i+1).reduce((s,v)=>s+v,0)/Math.min(i+1,12);return{x:xs[i],y:H-Math.round((a-mn)/rng*H*.86+H*.07)};}).filter(Boolean);
    if(m25.length>1){const p=document.createElementNS('http://www.w3.org/2000/svg','path');p.setAttribute('d',`M${m25.map(p=>p.x+' '+p.y).join('L')}`);p.setAttribute('fill','none');p.setAttribute('stroke','#3b82f6');p.setAttribute('stroke-width','1.5');p.setAttribute('stroke-dasharray','5 3');svg.appendChild(p);}
  }
  const dot=document.createElementNS('http://www.w3.org/2000/svg','circle');
  dot.setAttribute('cx',xs[xs.length-1]);dot.setAttribute('cy',ys[ys.length-1]);dot.setAttribute('r','4');dot.setAttribute('fill',lc);svg.appendChild(dot);
  area.appendChild(svg);
}

