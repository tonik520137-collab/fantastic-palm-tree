<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="株アシスト">
<meta name="theme-color" content="#ffffff">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icons/icon-192.png">
<title>株アシスト for iSPEED</title>
<style>
:root {
  --bg: #ffffff;
  --bg2: #f5f5f5;
  --bg3: #eeeeee;
  --text: #1a1a1a;
  --text2: #666666;
  --text3: #999999;
  --border: rgba(0,0,0,0.1);
  --border2: rgba(0,0,0,0.2);
  --blue: #1a73e8;
  --blue-bg: #e8f0fe;
  --blue-text: #1a56c4;
  --green: #1a8a50;
  --green-bg: #e6f4ea;
  --green-text: #1a6e3e;
  --red: #d32f2f;
  --red-bg: #fce8e6;
  --red-text: #b71c1c;
  --orange: #e65100;
  --orange-bg: #fff3e0;
  --orange-text: #bf360c;
  --purple-bg: #ede7f6;
  --purple-text: #4527a0;
  --radius: 12px;
  --radius-sm: 8px;
  --safe-bottom: env(safe-area-inset-bottom, 0px);
}
@media (prefers-color-scheme: dark) {
  :root {
    --bg: #121212;
    --bg2: #1e1e1e;
    --bg3: #2a2a2a;
    --text: #f0f0f0;
    --text2: #aaaaaa;
    --text3: #666666;
    --border: rgba(255,255,255,0.1);
    --border2: rgba(255,255,255,0.2);
    --blue-bg: #1a2a4a;
    --blue-text: #7aabf5;
    --green-bg: #1a2e1e;
    --green-text: #5dbf80;
    --red-bg: #2e1a1a;
    --red-text: #f07070;
    --orange-bg: #2e1e0a;
    --orange-text: #f0a060;
    --purple-bg: #2a1e3a;
    --purple-text: #c0a0f0;
  }
}
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Noto Sans JP', sans-serif; background: var(--bg); color: var(--text); font-size: 15px; overflow-x: hidden; }
.screen { display: none; min-height: 100dvh; padding-bottom: calc(64px + var(--safe-bottom)); }
.screen.active { display: block; }

/* nav bar */
.nav { position: fixed; bottom: 0; left: 0; right: 0; height: calc(56px + var(--safe-bottom)); background: var(--bg); border-top: 0.5px solid var(--border); display: flex; padding-bottom: var(--safe-bottom); z-index: 100; }
.nav-btn { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; cursor: pointer; color: var(--text3); font-size: 10px; padding: 6px 0; border: none; background: none; }
.nav-btn.active { color: var(--blue); }
.nav-icon { font-size: 20px; line-height: 1; }

/* header */
.header { background: var(--bg); border-bottom: 0.5px solid var(--border); padding: 14px 16px 10px; position: sticky; top: 0; z-index: 50; }
.header h1 { font-size: 18px; font-weight: 600; }
.header-sub { font-size: 12px; color: var(--text2); margin-top: 2px; }

/* cards */
.card { background: var(--bg); border: 0.5px solid var(--border); border-radius: var(--radius); padding: 14px; margin: 10px 12px; }
.card-title { font-size: 11px; font-weight: 600; color: var(--text2); letter-spacing: .06em; margin-bottom: 10px; text-transform: uppercase; }

/* badges */
.badge { display: inline-block; font-size: 10px; padding: 2px 8px; border-radius: 20px; font-weight: 600; margin: 0 3px 3px 0; }
.badge-up { background: var(--green-bg); color: var(--green-text); }
.badge-dn { background: var(--red-bg); color: var(--red-text); }
.badge-blue { background: var(--blue-bg); color: var(--blue-text); }
.badge-orange { background: var(--orange-bg); color: var(--orange-text); }
.badge-purple { background: var(--purple-bg); color: var(--purple-text); }

/* chips */
.chip-row { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 10px; }
.chip { font-size: 12px; padding: 5px 12px; border: 0.5px solid var(--border2); border-radius: 20px; cursor: pointer; color: var(--text2); background: var(--bg); white-space: nowrap; }
.chip.active { background: var(--blue-bg); color: var(--blue-text); border-color: var(--blue); }

/* stock rows */
.stock-row { display: flex; align-items: center; gap: 10px; padding: 12px 16px; border-bottom: 0.5px solid var(--border); cursor: pointer; }
.stock-row:active { background: var(--bg2); }
.stock-row:last-child { border-bottom: none; }
.s-code { font-size: 12px; color: var(--text2); width: 38px; flex-shrink: 0; }
.s-name { flex: 1; font-size: 14px; font-weight: 500; min-width: 0; }
.s-right { text-align: right; flex-shrink: 0; }
.s-price { font-size: 15px; font-weight: 600; }
.s-chg { font-size: 11px; margin-top: 1px; }

/* metrics grid */
.metric-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
.metric-box { background: var(--bg2); border-radius: var(--radius-sm); padding: 10px 8px; text-align: center; cursor: pointer; }
.metric-label { font-size: 10px; color: var(--text2); margin-bottom: 4px; }
.metric-val { font-size: 16px; font-weight: 600; }
.metric-hint { display: none; font-size: 11px; color: var(--text2); line-height: 1.5; margin-top: 6px; text-align: left; padding: 6px 8px; background: var(--bg); border-radius: 6px; }

/* meter */
.meter { margin-bottom: 10px; }
.meter-head { display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 4px; }
.meter-track { height: 6px; background: var(--bg3); border-radius: 3px; overflow: hidden; }
.meter-fill { height: 100%; border-radius: 3px; }

/* signal rows */
.sig-row { display: flex; align-items: flex-start; gap: 10px; padding: 8px 0; border-bottom: 0.5px solid var(--border); }
.sig-row:last-child { border-bottom: none; }
.sig-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 4px; }
.sig-body { flex: 1; }
.sig-name { font-size: 13px; font-weight: 500; }
.sig-hint { font-size: 11px; color: var(--text2); margin-top: 2px; line-height: 1.5; }
.sig-val { font-size: 11px; font-weight: 600; text-align: right; flex-shrink: 0; padding-top: 3px; }

/* strategy cards */
.strat { border-radius: var(--radius-sm); padding: 12px; margin-bottom: 8px; border: 1px solid transparent; }
.strat.best { border-width: 2px; }
.strat-day { background: var(--bg2); }
.strat-short { background: var(--blue-bg); border-color: var(--blue); }
.strat-short .strat-title { color: var(--blue-text); }
.strat-short .strat-body { color: var(--blue-text); opacity: .85; }
.strat-long { background: var(--purple-bg); border-color: var(--purple-text); }
.strat-long .strat-title { color: var(--purple-text); }
.strat-long .strat-body { color: var(--purple-text); opacity: .85; }
.strat-title { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
.strat-body { font-size: 12px; line-height: 1.6; }

/* price boxes */
.price-row { display: flex; gap: 8px; margin-bottom: 14px; }
.price-box { flex: 1; background: var(--bg2); border-radius: var(--radius-sm); padding: 10px 6px; text-align: center; }
.price-label { font-size: 10px; color: var(--text2); margin-bottom: 3px; }
.price-val { font-size: 15px; font-weight: 700; }

/* buttons */
.btn { width: 100%; padding: 14px; border: none; border-radius: var(--radius-sm); font-size: 15px; font-weight: 600; cursor: pointer; margin-bottom: 8px; }
.btn-blue { background: var(--blue-bg); color: var(--blue-text); }
.btn-outline { background: transparent; color: var(--text2); border: 0.5px solid var(--border2); }

/* tabs */
.tab-bar { display: flex; border-bottom: 0.5px solid var(--border); margin-bottom: 12px; overflow-x: auto; }
.tab { flex: none; padding: 9px 14px; font-size: 12px; cursor: pointer; color: var(--text2); border-bottom: 2px solid transparent; white-space: nowrap; }
.tab.active { color: var(--blue); border-bottom-color: var(--blue); font-weight: 600; }

/* AI box */
.ai-box { background: var(--blue-bg); border-radius: var(--radius-sm); padding: 12px; font-size: 13px; color: var(--blue-text); line-height: 1.7; margin-bottom: 10px; }
.ai-loading { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text2); }
.spinner { width: 18px; height: 18px; border: 2px solid var(--border2); border-top-color: var(--blue); border-radius: 50%; animation: spin .8s linear infinite; flex-shrink: 0; }
@keyframes spin { to { transform: rotate(360deg); } }

/* news */
.news-item { padding: 10px 0; border-bottom: 0.5px solid var(--border); }
.news-item:last-child { border-bottom: none; }
.news-date { font-size: 10px; color: var(--text3); margin-bottom: 3px; }
.news-title { font-size: 13px; font-weight: 500; line-height: 1.5; margin-bottom: 4px; }
.news-body { font-size: 11px; color: var(--text2); line-height: 1.5; }

/* SL box */
.sl-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 0.5px solid var(--border); font-size: 13px; }
.sl-row:last-child { border-bottom: none; }

/* order form */
.form-row { margin-bottom: 14px; }
.form-label { font-size: 12px; color: var(--text2); margin-bottom: 5px; font-weight: 600; }
.form-input { width: 100%; height: 44px; border: 0.5px solid var(--border2); border-radius: var(--radius-sm); padding: 0 12px; font-size: 16px; background: var(--bg); color: var(--text); }
.seg { display: flex; border: 0.5px solid var(--border2); border-radius: var(--radius-sm); overflow: hidden; }
.seg-btn { flex: 1; padding: 10px; text-align: center; font-size: 14px; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--text2); border: none; }
.seg-btn.active-buy { background: var(--green-bg); color: var(--green-text); }
.seg-btn.active-sell { background: var(--red-bg); color: var(--red-text); }
.total-box { background: var(--bg2); border-radius: var(--radius-sm); padding: 12px; }
.total-row { display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 4px; }
.total-row:last-child { margin-bottom: 0; }
.warn-box { background: var(--orange-bg); border-radius: var(--radius-sm); padding: 10px 12px; font-size: 12px; color: var(--orange-text); margin-top: 8px; line-height: 1.5; }
.good-box { background: var(--green-bg); border-radius: var(--radius-sm); padding: 10px 12px; font-size: 12px; color: var(--green-text); line-height: 1.6; margin-bottom: 10px; }

/* guide steps */
.guide-step { display: flex; gap: 12px; padding: 10px 0; border-bottom: 0.5px solid var(--border); }
.guide-step:last-child { border-bottom: none; }
.guide-num { width: 26px; height: 26px; border-radius: 50%; background: var(--blue-bg); color: var(--blue-text); font-size: 12px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.guide-text { font-size: 13px; font-weight: 500; margin-bottom: 2px; }
.guide-sub { font-size: 12px; color: var(--text2); line-height: 1.5; }

/* heatmap */
.heat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 5px; }
.heat-cell { border-radius: var(--radius-sm); padding: 10px 4px; text-align: center; cursor: pointer; }
.heat-name { font-size: 11px; font-weight: 600; margin-bottom: 3px; }
.heat-chg { font-size: 13px; font-weight: 700; }

/* watchlist */
.watch-row { display: flex; flex-direction: column; gap: 6px; padding: 12px 16px; border-bottom: 0.5px solid var(--border); cursor: pointer; }
.watch-row:active { background: var(--bg2); }
.watch-top { display: flex; align-items: center; gap: 8px; }
.watch-tags { display: flex; gap: 5px; }

/* API key setup */
.api-setup { padding: 20px 16px; }
.api-setup h2 { font-size: 18px; font-weight: 700; margin-bottom: 8px; }
.api-setup p { font-size: 13px; color: var(--text2); line-height: 1.7; margin-bottom: 14px; }
.api-input { width: 100%; height: 44px; border: 0.5px solid var(--border2); border-radius: var(--radius-sm); padding: 0 12px; font-size: 14px; background: var(--bg); color: var(--text); margin-bottom: 10px; }
.step-bar { display: flex; gap: 4px; margin-bottom: 16px; }
.step-dot { flex: 1; height: 4px; border-radius: 2px; background: var(--bg3); }
.step-dot.done { background: var(--blue); }

/* chart area */
#main-chart { position: relative; height: 110px; margin-bottom: 8px; }
</style>
</head>
<body>

<!-- ===== SCREEN: HOME (銘柄選択) ===== -->
<div id="scr-home" class="screen active">
  <div class="header">
    <h1>株アシスト</h1>
    <div class="header-sub">iSPEED 補助ツール</div>
  </div>

  <div style="padding:10px 12px 4px">
    <div class="chip-row" id="home-filter">
      <span class="chip active" data-f="all">すべて</span>
      <span class="chip" data-f="day">デイトレ</span>
      <span class="chip" data-f="short">短期</span>
      <span class="chip" data-f="long">長期</span>
      <span class="chip" data-f="stable">安定重視</span>
      <span class="chip" data-f="growth">リターン重視</span>
    </div>
  </div>

  <div id="home-list"></div>
</div>

<!-- ===== SCREEN: ANALYSIS (分析) ===== -->
<div id="scr-analysis" class="screen">
  <div class="header" style="display:flex;align-items:center;gap:10px">
    <button onclick="showScreen('home')" style="background:none;border:none;font-size:20px;cursor:pointer;padding:0;color:var(--text)">←</button>
    <div style="flex:1">
      <div id="a-name" style="font-size:17px;font-weight:700"></div>
      <div id="a-meta" style="font-size:11px;color:var(--text2)"></div>
    </div>
    <span id="watch-star" onclick="toggleWatch()" style="font-size:24px;cursor:pointer"></span>
  </div>

  <div style="padding:10px 12px 0">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:8px">
      <div>
        <div id="a-price" style="font-size:28px;font-weight:700"></div>
        <div id="a-chg"></div>
      </div>
      <div style="text-align:right;font-size:11px;color:var(--text2)">
        <div>高値 <span id="a-high" style="color:var(--green)"></span></div>
        <div>安値 <span id="a-low" style="color:var(--red)"></span></div>
      </div>
    </div>
    <div id="main-chart"></div>
    <div class="chip-row" id="chart-periods">
      <span class="chip active" data-p="1d">1日</span>
      <span class="chip" data-p="1w">1週</span>
      <span class="chip" data-p="1m">1か月</span>
      <span class="chip" data-p="3m">3か月</span>
    </div>
    <div style="display:flex;gap:12px;font-size:11px;color:var(--text2);margin-bottom:4px">
      <span style="display:flex;align-items:center;gap:4px"><span style="width:16px;height:2px;background:#f59e0b;display:inline-block;border-radius:1px"></span>5日平均</span>
      <span style="display:flex;align-items:center;gap:4px"><span style="width:16px;height:2px;background:#3b82f6;display:inline-block;border-radius:1px"></span>25日平均</span>
    </div>
  </div>

  <div style="padding:0 12px">
    <div class="card" style="margin:10px 0">
      <div class="tab-bar">
        <div class="tab active" data-tab="fund">ファンダメンタル</div>
        <div class="tab" data-tab="tech">テクニカル</div>
        <div class="tab" data-tab="sig">シグナル</div>
        <div class="tab" data-tab="news">最新材料</div>
      </div>
      <div id="tab-fund"></div>
      <div id="tab-tech" style="display:none"></div>
      <div id="tab-sig" style="display:none"></div>
      <div id="tab-news" style="display:none"></div>
    </div>

    <div class="card" style="margin:0 0 10px">
      <div class="card-title">AI 分析 <span id="ai-status" style="font-size:10px;color:var(--text3);font-weight:400"></span></div>
      <div id="ai-content">
        <div class="ai-loading">
          <div class="spinner"></div>
          <span>AIが分析中...</span>
        </div>
      </div>
    </div>

    <div class="card" style="margin:0 0 10px">
      <div class="card-title">損切りライン</div>
      <div id="sl-content"></div>
    </div>

    <div class="card" style="margin:0 0 10px">
      <div class="card-title">作戦提案</div>
      <div id="strat-content"></div>
    </div>

    <div class="card" style="margin:0 0 10px">
      <div class="card-title">推奨価格帯</div>
      <div class="price-row" id="price-row"></div>
      <button class="btn btn-blue" onclick="goToOrder()">この銘柄で注文を組む →</button>
    </div>
  </div>
</div>

<!-- ===== SCREEN: ORDER (注文) ===== -->
<div id="scr-order" class="screen">
  <div class="header" style="display:flex;align-items:center;gap:10px">
    <button onclick="showScreen('analysis')" style="background:none;border:none;font-size:20px;cursor:pointer;padding:0;color:var(--text)">←</button>
    <div style="font-size:17px;font-weight:700">注文を組む</div>
  </div>
  <div style="padding:12px 16px">
    <div style="margin-bottom:14px;font-size:13px;color:var(--text2)" id="order-stock-info"></div>

    <div class="form-row">
      <div class="form-label">売買区分</div>
      <div class="seg">
        <button class="seg-btn active-buy" id="side-buy" onclick="setSide('buy')">買い</button>
        <button class="seg-btn" id="side-sell" onclick="setSide('sell')">売り</button>
      </div>
    </div>
    <div class="form-row">
      <div class="form-label">指値（円）</div>
      <input class="form-input" type="number" id="inp-price" inputmode="numeric" placeholder="例：3250" oninput="calcOrder()">
    </div>
    <div class="form-row">
      <div class="form-label">株数（100株単位）</div>
      <input class="form-input" type="number" id="inp-qty" inputmode="numeric" placeholder="例：100" step="100" oninput="calcOrder()">
    </div>
    <div class="form-row">
      <div class="form-label">利確目安</div>
      <div class="chip-row" id="tp-chips">
        <span class="chip" onclick="setTP(1)">+1%</span>
        <span class="chip" onclick="setTP(2)">+2%</span>
        <span class="chip" onclick="setTP(3)">+3%</span>
        <span class="chip" onclick="setTP(5)">+5%</span>
      </div>
    </div>
    <div class="total-box" id="order-total">
      <div class="total-row"><span style="color:var(--text2)">概算合計</span><span style="font-weight:700" id="tot-amount">— 円</span></div>
      <div class="total-row"><span style="color:var(--text2)">損切ライン（-5%）</span><span style="color:var(--red)" id="tot-sl">— 円</span></div>
      <div class="total-row"><span style="color:var(--text2)">余剰資金上限（5%）</span><span style="color:var(--text3)">75,000 円</span></div>
    </div>
    <div id="order-warn" style="display:none" class="warn-box">上限75,000円を超えています。株数を減らすか指値を下げてください。</div>
    <button class="btn btn-blue" style="margin-top:14px" onclick="goToConfirm()">確認画面へ →</button>
  </div>
</div>

<!-- ===== SCREEN: CONFIRM (確認) ===== -->
<div id="scr-confirm" class="screen">
  <div class="header" style="display:flex;align-items:center;gap:10px">
    <button onclick="showScreen('order')" style="background:none;border:none;font-size:20px;cursor:pointer;padding:0;color:var(--text)">←</button>
    <div style="font-size:17px;font-weight:700">注文確認</div>
  </div>
  <div style="padding:12px 16px">
    <div class="card" style="margin:0 0 10px">
      <div class="card-title">注文内容</div>
      <div id="confirm-summary"></div>
    </div>
    <div class="warn-box" style="margin-bottom:14px">最終確認です。iSPEED を開いてパスワードを入力してください。</div>
    <button class="btn btn-blue" onclick="showScreen('guide')">iSPEED で注文する →</button>
    <button class="btn btn-outline" onclick="showScreen('order')">内容を修正する</button>
  </div>
</div>

<!-- ===== SCREEN: GUIDE (操作ガイド) ===== -->
<div id="scr-guide" class="screen">
  <div class="header" style="display:flex;align-items:center;gap:10px">
    <button onclick="showScreen('confirm')" style="background:none;border:none;font-size:20px;cursor:pointer;padding:0;color:var(--text)">←</button>
    <div style="font-size:17px;font-weight:700">iSPEED 操作ガイド</div>
  </div>
  <div style="padding:12px 16px">
    <div class="card" style="margin:0 0 10px">
      <div id="guide-summary" style="background:var(--bg2);border-radius:var(--radius-sm);padding:10px;margin-bottom:14px;font-size:13px"></div>
      <div class="guide-step">
        <div class="guide-num">1</div>
        <div><div class="guide-text">iSPEED アプリを開く</div><div class="guide-sub">楽天証券のiSPEEDアプリを起動</div></div>
      </div>
      <div class="guide-step">
        <div class="guide-num">2</div>
        <div><div class="guide-text">下メニュー「取引」→「国内株式」</div><div class="guide-sub">→「現物買い」（または「現物売り」）を選択</div></div>
      </div>
      <div class="guide-step">
        <div class="guide-num">3</div>
        <div><div class="guide-text">銘柄コードを入力</div><div class="guide-sub" id="g-code"></div></div>
      </div>
      <div class="guide-step">
        <div class="guide-num">4</div>
